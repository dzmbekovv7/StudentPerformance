```gitignore
# =========================================================
# Python
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# =========================================================
# Virtual Environment
# =========================================================
venv/
.venv/
env/
ENV/
virtualenv/

# =========================================================
# Environment Variables
# =========================================================
.env
.env.*
!.env.example

# =========================================================
# Django
# =========================================================
db.sqlite3
db.sqlite3-journal

*.log
logs/
media/

staticfiles/
static_root/

# Django cache
*.mo
*.pot

# =========================================================
# Migrations (optional)
# Uncomment if you DON'T want migrations in git.
# Usually keep migrations for real projects.
# =========================================================
# **/migrations/
# !**/migrations/__init__.py

# =========================================================
# Machine Learning
# =========================================================

# Trained models
*.pkl
*.pickle
*.joblib
*.h5
*.keras
*.pt
*.pth
*.onnx
*.ckpt

# TensorBoard
runs/
tensorboard/

# MLflow
mlruns/

# Weights & Biases
wandb/

# DVC
.dvc/
.dvcignore

# Dataset cache
.cache/

# =========================================================
# Data
# Keep small example datasets if needed.
# =========================================================
data/
datasets/

# =========================================================
# Jupyter
# =========================================================
.ipynb_checkpoints/
*.nbconvert.ipynb

# =========================================================
# VS Code
# =========================================================
.vscode/

# =========================================================
# PyCharm
# =========================================================
.idea/

# =========================================================
# Testing
# =========================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# =========================================================
# Type Checking
# =========================================================
.mypy_cache/
.pyre/
.pytype/

# =========================================================
# Ruff / Black
# =========================================================
.ruff_cache/

# =========================================================
# Build
# =========================================================
build/
dist/
*.egg-info/
.eggs/

# =========================================================
# OS
# =========================================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# Temporary
# =========================================================
tmp/
temp/
*.tmp
*.bak
*.swp

# =========================================================
# Secrets
# =========================================================
*.pem
*.key
*.crt

# =========================================================
# Node (if frontend exists)
# =========================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================================
# Python packaging
# =========================================================
pip-wheel-metadata/
```
